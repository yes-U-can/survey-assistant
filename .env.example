# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DEFAULT_LOCALE=ko
SUPPORTED_LOCALES=ko,en

# Database (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PLATFORM_ADMIN_EMAILS=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# AI (BYOK adapter defaults)
AI_PROVIDER_DEFAULT=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AI_OPENAI_MODEL=gpt-4.1-mini
AI_OPENAI_TEMPERATURE=0.2
AI_MANAGED_CREDIT_MIN_PER_REQUEST=1
AI_MANAGED_CREDIT_PER_1K_INPUT_TOKENS=1
AI_MANAGED_CREDIT_PER_1K_OUTPUT_TOKENS=2
AI_MANAGED_CREDIT_PER_REQUEST=1

# Security
ENCRYPTION_KEY=
