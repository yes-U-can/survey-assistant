# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DEFAULT_LOCALE=ko
SUPPORTED_LOCALES=ko,en

# Database (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
PLATFORM_ADMIN_EMAILS=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AUTH_SESSION_MAX_AGE_SEC=604800
AUTH_SESSION_UPDATE_AGE_SEC=86400
AUTH_PARTICIPANT_LOGIN_RATE_LIMIT=10
AUTH_PARTICIPANT_LOGIN_WINDOW_SEC=60

# AI (BYOK adapter defaults)
AI_PROVIDER_DEFAULT=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AI_OPENAI_MODEL=gpt-4.1-mini
AI_OPENAI_TEMPERATURE=0.2
AI_MANAGED_CREDIT_PER_REQUEST=1

# Platform alert thresholds
PLATFORM_ALERT_MIN_TOTAL_CREDITS=500
PLATFORM_ALERT_MAX_OPEN_SPECIAL_REQUESTS=12
PLATFORM_ALERT_MAX_RUNNING_MIGRATIONS=5
PLATFORM_ALERT_MAX_FAILED_MIGRATIONS=3
PLATFORM_ALERT_STALE_SPECIAL_REQUEST_DAYS=14
PLATFORM_ALERT_MAX_STALE_SPECIAL_REQUESTS=0

# Security
ENCRYPTION_KEY=
